# Neon Postgres (Vercel Storage integration can create this automatically)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Vercel Blob read/write token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_example

# Exact public production origin. No trailing path.
PUBLIC_BASE_URL=https://your-project.vercel.app

# Optional. Required only for administrative skin upload endpoints.
ADMIN_API_KEY=

# Enable public account registration after storage is connected.
REGISTRATION_ENABLED=true

# Optional tuning
SESSION_COOKIE_NAME=__Host-tiramisu_session
SESSION_LIFETIME_SECONDS=604800
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=900
API_RATE_LIMIT_MAX=120
API_RATE_LIMIT_WINDOW_SECONDS=60
